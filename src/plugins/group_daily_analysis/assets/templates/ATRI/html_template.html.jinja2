                    </div>
                    <div style="font-size: 13px; opacity: 0.85;">亚托莉会永远把大家珍贵的聊天记忆藏在海底哦。</div>
                </div>
            </footer>
        </div>
    </div>

    <script>
        /* ==========================================
           NUMBER COUNTER ANIMATION
        ========================================== */
        (function () {
            function animateCount(el, target, duration) {
                const start = performance.now();
                const startVal = 0;
                function step(now) {
                    const elapsed = now - start;
                    const progress = Math.min(elapsed / duration, 1);
                    // Ease out cubic
                    const ease = 1 - Math.pow(1 - progress, 3);
                    const current = Math.round(startVal + (target - startVal) * ease);
                    el.textContent = current.toLocaleString();
                    if (progress < 1) requestAnimationFrame(step);
                }
                requestAnimationFrame(step);
            }

            function tryAnimate() {
                // Stat values
                document.querySelectorAll('.stat-value').forEach(el => {
                    const raw = el.textContent.trim().replace(/,/g, '');
                    const num = parseFloat(raw);
                    if (!isNaN(num) && num > 0) animateCount(el, num, 1200);
                });
                // Token values
                document.querySelectorAll('.token-value').forEach(el => {
                    const raw = el.textContent.trim().replace(/,/g, '');
                    const num = parseFloat(raw);
                    if (!isNaN(num) && num > 0) animateCount(el, num, 1600);
                });
            }

            // Run after a short delay to let the page paint
            setTimeout(tryAnimate, 400);
        })();

        /* ==========================================
           ENTRANCE RIPPLE ON SECTION CLICK
        ========================================== */
        document.querySelectorAll('.section, .stat-card, .token-card').forEach(el => {
            el.addEventListener('click', function (e) {
                const rect = el.getBoundingClientRect();
                const rippleX = e.clientX - rect.left;
                const rippleY = e.clientY - rect.top;
                const ripple = document.createElement('span');
                ripple.className = 'click-kawaii-burst';
                ripple.style.left = `${rippleX}px`;
                ripple.style.top = `${rippleY}px`;
                ripple.innerHTML = `
                <span class="burst-core"></span>
                <span class="burst-ring"></span>
                <span class="burst-sparkle sparkle-1"></span>
                <span class="burst-sparkle sparkle-2"></span>
                <span class="burst-sparkle sparkle-3"></span>
                <span class="burst-heart"></span>
            `;
                el.style.position = 'relative';
                el.style.overflow = 'hidden';
                el.appendChild(ripple);
                setTimeout(() => ripple.remove(), 900);
            });
        });
        // Inject ripple keyframe dynamically
        const styleEl = document.createElement('style');
        styleEl.textContent = `
    .click-kawaii-burst {
        position: absolute;
        width: 0;
        height: 0;
        pointer-events: none;
        z-index: 30;
    }
    .click-kawaii-burst > span {
        position: absolute;
        left: 0;
        top: 0;
        transform: translate(-50%, -50%);
        pointer-events: none;
    }
    .click-kawaii-burst .burst-core {
        width: 18px;
        height: 18px;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(255,255,255,0.98) 0%, rgba(255,214,242,0.95) 42%, rgba(156,220,255,0.86) 100%);
        box-shadow: 0 0 0 6px rgba(255,255,255,0.18), 0 0 18px rgba(151, 222, 255, 0.45);
        animation: kawaiiPop 0.72s ease-out forwards;
    }
    .click-kawaii-burst .burst-ring {
        width: 22px;
        height: 22px;
        border-radius: 999px;
        border: 2px solid rgba(255,255,255,0.9);
        box-shadow: 0 0 0 1px rgba(154, 219, 255, 0.28) inset;
        animation: kawaiiRing 0.78s ease-out forwards;
    }
    .click-kawaii-burst .burst-sparkle {
        width: 10px;
        height: 10px;
        border-radius: 3px;
        transform: translate(-50%, -50%) rotate(45deg);
        background: linear-gradient(135deg, #fff7b8, #ffd8f3);
        box-shadow: 0 0 10px rgba(255, 214, 120, 0.35);
    }
    .click-kawaii-burst .sparkle-1 { animation: sparkleOne 0.82s ease-out forwards; }
    .click-kawaii-burst .sparkle-2 { animation: sparkleTwo 0.82s ease-out forwards; }
    .click-kawaii-burst .sparkle-3 { animation: sparkleThree 0.82s ease-out forwards; }
    .click-kawaii-burst .burst-heart {
        width: 12px;
        height: 12px;
        background: linear-gradient(135deg, #ffb7df, #ffc9a8);
        transform: translate(-50%, -50%) rotate(-45deg);
        border-radius: 3px 3px 1px 1px;
        box-shadow: 0 0 12px rgba(255, 170, 214, 0.38);
        animation: heartFloat 0.9s ease-out forwards;
    }
    .click-kawaii-burst .burst-heart::before,
    .click-kawaii-burst .burst-heart::after {
        content: "";
        position: absolute;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: inherit;
    }
    .click-kawaii-burst .burst-heart::before {
        left: 0;
        top: -6px;
    }
    .click-kawaii-burst .burst-heart::after {
        left: 6px;
        top: 0;
    }
    @keyframes kawaiiPop {
        0% { opacity: 0.95; transform: translate(-50%, -50%) scale(0.2); }
        65% { opacity: 0.9; transform: translate(-50%, -50%) scale(1.5); }
        100% { opacity: 0; transform: translate(-50%, -50%) scale(2.2); }
    }
    @keyframes kawaiiRing {
        0% { opacity: 0.8; transform: translate(-50%, -50%) scale(0.3); }
        100% { opacity: 0; transform: translate(-50%, -50%) scale(4.8); }
    }
    @keyframes sparkleOne {
        0% { opacity: 0; transform: translate(-50%, -50%) rotate(45deg) scale(0.2); }
        35% { opacity: 1; }
        100% { opacity: 0; transform: translate(calc(-50% - 24px), calc(-50% - 28px)) rotate(120deg) scale(1.15); }
    }
    @keyframes sparkleTwo {
        0% { opacity: 0; transform: translate(-50%, -50%) rotate(45deg) scale(0.2); }
        35% { opacity: 1; }
        100% { opacity: 0; transform: translate(calc(-50% + 28px), calc(-50% - 16px)) rotate(160deg) scale(1.05); }
    }
    @keyframes sparkleThree {
        0% { opacity: 0; transform: translate(-50%, -50%) rotate(45deg) scale(0.2); }
        35% { opacity: 1; }
        100% { opacity: 0; transform: translate(calc(-50% + 12px), calc(-50% + 26px)) rotate(135deg) scale(0.95); }
    }
    @keyframes heartFloat {
        0% { opacity: 0; transform: translate(-50%, -50%) rotate(-45deg) scale(0.2); }
        25% { opacity: 1; }
        100% { opacity: 0; transform: translate(calc(-50% - 18px), calc(-50% - 34px)) rotate(-25deg) scale(1.05); }
    }`;
        document.head.appendChild(styleEl);
    </script>
</body>

</html>