<!DOCTYPE html>
<html lang="{{ 'zh-CN' if t2i_font_source == 'Mainland' else 'zh-Hant' }}">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ATRI 群聊日报 · {{ current_date }}</title>
    <style>
        @font-face {
            font-family: 'LXGW WenKai';
            src: url('{{ t2i_atri_font_mirror }}/file/1775130743963_1774880718993_LXGWWenKai-Regular.woff2') format('woff2');
            font-weight: 400;
        }

        @font-face {
            font-family: 'LXGW WenKai';
            src: url('{{ t2i_atri_font_mirror }}/file/1775130739223_1774880715380_LXGWWenKai-Medium.woff2') format('woff2');
            font-weight: 600;
        }

        @font-face {
            font-family: 'LXGW WenKai Mono';
            src: url('{{ t2i_atri_font_mirror }}/file/1775130738049_1774880717027_LXGWWenKaiMono-Regular.woff2') format('woff2');
            font-weight: 400;
        }

        :root {
            --sky: #8fc5ff;
            --sea: #6d9afa;
            --deep: #5A4C5A;
            --foam: #f5f8ff;
            --paper: #fffdfc;
            --blossom: #ffb3c6;
            --peach: #ffd3b6;
            --mint: #a8e6cf;
            --lilac: #dcd3ff;
            --lemon: #fff3b0;
            --card: rgba(255, 255, 255, 0.85);
            --card-strong: rgba(255, 255, 255, 0.95);
            --border: rgba(255, 255, 255, 0.9);
            --shadow: rgba(90, 76, 90, 0.08);
            --text-main: #5E5358;
            --text-sub: #8D818A;
            --accent: #ffbaba;
            --quote: #dcd3ff;
            --radius-xl: 28px;
            --radius-lg: 22px;
            --radius-md: 18px;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;

            font-family: 'LXGW WenKai',
            {
            % if t2i_font_source=='Mainland' %
        }

        'Noto Sans SC',
        'Noto Sans TC' {
            % else %
        }

        'Noto Sans TC',
        'Noto Sans SC' {
            % endif %
        }

        ,
        'Microsoft YaHei',
        sans-serif;
        color: var(--text-main);
        background: transparent;
        }

        .page {
            max-width: 1020px;
            margin: 0 auto;
            position: relative;
            border-radius: var(--radius-xl);
            padding: 36px 18px 60px;
            background-color: #dff4ff;
            background-image: linear-gradient(180deg, rgba(255, 255, 255, 0.80), rgba(242, 251, 255, 0.94)),
            linear-gradient(rgba(239, 250, 255, 0.72), rgba(239, 250, 255, 0.92)),
            radial-gradient(circle at 15% 12%, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0) 26%),
            linear-gradient(rgba(117, 193, 240, 0.08) 1px, transparent 1px),
            linear-gradient(90deg, rgba(117, 193, 240, 0.08) 1px, transparent 1px),
            url('{{ t2i_atri_font_mirror }}/file/1775130588385_1774881257527_bg1.webp');
            background-size: auto, auto, auto, 26px 26px, 26px 26px, cover;
            background-position: center, center, center, center, center, center;
            border: 1px solid var(--border);
            box-shadow: 0 24px 70px var(--shadow);
            overflow: hidden;
            backdrop-filter: blur(10px);
        }

        .page::before {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at top right, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0) 25%),
                radial-gradient(circle at bottom left, rgba(116, 200, 243, 0.16), rgba(116, 200, 243, 0) 33%),
                radial-gradient(circle at 20% 30%, rgba(118, 196, 240, 0.1) 0 2px, transparent 2px 100%);
            background-size: auto, auto, 22px 22px;
            pointer-events: none;
        }

        .page::after {
            content: "ATRI";
            position: absolute;
            right: 40px;
            top: 10px;
            font-family: 'LXGW WenKai Mono', monospace;
            font-size: 156px;
            line-height: 1;
            letter-spacing: 6px;
            color: rgba(75, 169, 220, 0.35);
            pointer-events: none;
            z-index: 10;
        }

        .deco-bubble,
        .deco-bubble-2,
        .deco-ring,
        .deco-character,
        .float-sticker {
            position: absolute;
            pointer-events: none;
        }

        .deco-bubble {
            width: 240px;
            height: 240px;
            right: -60px;
            top: -70px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.86), rgba(143, 216, 255, 0.14) 58%, rgba(143, 216, 255, 0) 72%);
            opacity: 0.7;
        }

        .deco-bubble-2 {
            width: 170px;
            height: 170px;
            left: -40px;
            bottom: 130px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.82), rgba(114, 200, 244, 0.14) 60%, rgba(114, 200, 244, 0) 76%);
            opacity: 0.5;
        }

        .deco-ring {
            right: 76px;
            top: 124px;
            width: 180px;
            height: 180px;
            border-radius: 50%;
            border: 2px dashed rgba(114, 200, 244, 0.24);
            opacity: 0.9;
        }

        .deco-character {
            right: -8px;
            bottom: -18px;
            width: 440px;
            opacity: 0.68;
            z-index: 0;
            filter: brightness(1.18) saturate(1.12) contrast(1.03) drop-shadow(0 24px 48px rgba(69, 152, 205, 0.2));
        }

        .bottom-showcase {
            position: absolute;
            right: 18px;
            bottom: 0;
            width: 430px;
            height: 330px;
            border-radius: 36px;
            background:
                radial-gradient(circle at 58% 34%, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0) 34%),
                radial-gradient(circle at 50% 60%, rgba(123, 206, 245, 0.3), rgba(123, 206, 245, 0) 64%);
            filter: blur(8px);
            opacity: 1;
            pointer-events: none;
            z-index: 0;
        }

        .float-sticker {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 46px;
            height: 46px;
            border-radius: 14px;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(240, 249, 255, 0.78));
            border: 1px solid rgba(149, 210, 242, 0.34);
            box-shadow: 0 10px 24px rgba(83, 155, 195, 0.12);
            color: var(--sea);
            opacity: 0.92;
            z-index: 1;
        }

        .float-sticker .icon-svg {
            width: 20px;
            height: 20px;
        }

        .icon-svg {
            width: 1em;
            height: 1em;
            display: inline-block;
            vertical-align: middle;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            flex: 0 0 auto;
        }

        .sticker-heart {
            top: 5%;
            left: -14px;
            color: #ff90b3;
        }

        .sticker-star {
            top: 8%;
            right: -10px;
            color: #7bcdf3;
        }

        .sticker-bow {
            top: 12%;
